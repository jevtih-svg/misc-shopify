{%- comment -%}
  MISC brands directory — homepage

  Data source: a Shopify menu (link_list). We render the sub-items of the
  parent menu item whose title matches `parent_title` (default "Brands").
  Each sub-item is a per-brand page link, so the section stays in sync with
  the Brands submenu in the header — add/remove a brand there and it appears
  here automatically. There is no "all brands" page, so there is no CTA.

  Fallback: if the menu yields no nested items, the manual "brand" blocks
  render instead, so the section is never empty in the Theme Editor.
{%- endcomment -%}

{{ 'misc-home.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign nav = linklists[section.settings.menu]
  assign target_title = section.settings.parent_title | default: 'Brands' | downcase
  assign brand_links = nil
  assign found = false

  comment
    First pass: the parent whose title matches (e.g. "Brands").
  endcomment
  for l in nav.links
    if found
      continue
    endif
    if l.links.size > 0
      assign lt = l.title | downcase
      if lt == target_title
        assign brand_links = l.links
        assign found = true
      endif
    endif
  endfor

  comment
    Fallback pass: the first menu item that has any children.
  endcomment
  if found == false
    for l in nav.links
      if found
        continue
      endif
      if l.links.size > 0
        assign brand_links = l.links
        assign found = true
      endif
    endfor
  endif

  assign brand_count = 0
  if found
    assign brand_count = brand_links.size
  else
    assign brand_count = section.blocks | where: 'type', 'brand' | size
  endif
-%}

<section class="misc-brands" aria-label="{{ section.settings.aria_label | default: 'Our brands' }}">
  <div class="misc-brands__head">
    <div>
      <span class="misc-brands__eyebrow">{{ section.settings.meta_label | default: 'Our brands' }}</span>
      {%- if section.settings.meta_subtitle != blank -%}
        <span class="misc-brands__sub"> · {{ section.settings.meta_subtitle }}</span>
      {%- endif -%}
    </div>
    <div class="misc-brands__meta">
      {%- if section.settings.show_count and brand_count > 0 -%}
        <span>{{ brand_count }} brands</span>
      {%- endif -%}
      {%- if section.settings.since_text != blank -%}
        <span>{{ section.settings.since_text }}</span>
      {%- endif -%}
    </div>
  </div>

  <div class="misc-brands__grid">
    {%- if found -%}
      {%- for brand in brand_links -%}
        <a href="{{ brand.url }}" class="misc-brands__cell{% if brand.active or brand.child_active %} is-active{% endif %}">
          <span>{{ brand.title }}</span>
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
        </a>
      {%- endfor -%}
    {%- else -%}
      {%- for block in section.blocks -%}
        {%- if block.type == 'brand' -%}
          <a href="{{ block.settings.url | default: '#' }}" class="misc-brands__cell" {{ block.shopify_attributes }}>
            <span>{{ block.settings.name }}</span>
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
          </a>
        {%- endif -%}
      {%- endfor -%}
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "MISC Brand Portfolio",
  "max_blocks": 30,
  "settings": [
    {
      "type": "header",
      "content": "Brand source"
    },
    {
      "type": "paragraph",
      "content": "The grid is built from the sub-items of one menu item (e.g. the \"Brands\" item in the header menu). Edit those links in Online Store → Navigation to change what appears here."
    },
    {
      "type": "link_list",
      "id": "menu",
      "label": "Menu",
      "default": "main-menu"
    },
    {
      "type": "text",
      "id": "parent_title",
      "label": "Parent item title",
      "info": "The title of the menu item whose sub-items are the brands.",
      "default": "Brands"
    },
    {
      "type": "header",
      "content": "Header row"
    },
    {
      "type": "text",
      "id": "meta_label",
      "label": "Label",
      "default": "Our brands"
    },
    {
      "type": "text",
      "id": "meta_subtitle",
      "label": "Subtitle (after dot)",
      "default": "Carefully selected, design-led stationery"
    },
    {
      "type": "checkbox",
      "id": "show_count",
      "label": "Show brand count",
      "default": true
    },
    {
      "type": "text",
      "id": "since_text",
      "label": "Right-side text",
      "default": "Established 2010"
    },
    {
      "type": "header",
      "content": "Accessibility"
    },
    {
      "type": "text",
      "id": "aria_label",
      "label": "Accessibility label",
      "default": "Our brands"
    }
  ],
  "blocks": [
    {
      "type": "brand",
      "name": "Brand (manual fallback)",
      "settings": [
        {
          "type": "text",
          "id": "name",
          "label": "Brand name",
          "default": "Brand"
        },
        {
          "type": "url",
          "id": "url",
          "label": "Brand link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "MISC Brand Portfolio"
    }
  ]
}
{% endschema %}
