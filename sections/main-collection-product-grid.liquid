{{ 'template-collection.css' | asset_url | stylesheet_tag }}
{{ 'component-card.css' | asset_url | stylesheet_tag }}
{{ 'component-price.css' | asset_url | stylesheet_tag }}

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

{%- comment -%}
  MISC: per_page is sourced from the section setting only.
  Shopify Liquid has no portable way to read arbitrary query
  params, so a user-facing per_page dropdown can't work
  server-side without complex template variants. The merchant
  configures products_per_page in the theme editor.
{%- endcomment -%}
{%- assign per_page = section.settings.products_per_page | plus: 0 -%}

{%- comment -%}
  MISC: server-side default for active layout. The user-facing
  layout toggle (Grid 3 / Grid 5 / List) runs entirely in JS via
  the ?layout= URL param (handled in misc-view-toggle.js). Server
  initially renders both grid and list, with the list hidden by
  default; JS applies the correct visibility on load.

  Shopify's ?view= param is reserved for template variants
  (collection.per-N.json for per-page), so we use ?layout= to
  avoid collision.
{%- endcomment -%}
{%- assign active_view = section.settings.default_view -%}
{%- if active_view == 'list' and section.settings.enable_list_view == false -%}
  {%- assign active_view = 'grid-3' -%}
{%- endif -%}

<div class="section-{{ section.id }}-padding gradient">

  {%- comment -%}
    MISC: the catalog is a first-class mobile experience now, so
    the old "best experienced on desktop" notice was removed
    2026-05-30. Do not reintroduce it.
  {%- endcomment -%}

  {%- paginate collection.products by per_page -%}

    {%- comment -%} MISC: full-width filter-bar row above the catalog body {%- endcomment -%}
    {%- if section.settings.enable_filtering or section.settings.enable_sorting -%}
      {% render 'misc-filter-bar',
        collection: collection,
        results_url: collection.url,
        active_view: active_view,
        per_page: per_page,
        enable_list_view: section.settings.enable_list_view
      %}
    {%- endif -%}

    <div class="facets-vertical page-width">
      {{ 'component-facets.css' | asset_url | stylesheet_tag }}
      <script src="{{ 'facets.js' | asset_url }}" defer="defer"></script>

      {%- comment -%}
        MISC: facets.js satisfier elements.

        facets.js references #FacetFiltersFormMobile.closest('menu-drawer').bindEvents()
        unconditionally inside renderActiveFacets. Without this hidden satisfier the
        call throws a TypeError on every AJAX filter change, breaking the entire
        reload flow (the "filter doesn't refresh the page" bug).

        The .active-facets-mobile and .active-facets-desktop empty containers
        satisfy the active-facets selector list at facets.js:180.
      {%- endcomment -%}
      <menu-drawer hidden class="misc-facets-js-satisfier" aria-hidden="true">
        <div id="FacetFiltersFormMobile"></div>
      </menu-drawer>
      <div class="active-facets-mobile" hidden aria-hidden="true"></div>
      {%- comment -%}
        The .active-facets-desktop element is the .misc-filter-bar
        itself (class applied in the snippet). Don't render an
        empty placeholder here — would duplicate the selector and
        confuse facets.js.
      {%- endcomment -%}

      <!-- Sidebar backdrop for mobile drawer (Phase 10) -->
      <div class="sidebar-backdrop" data-close-drawer aria-hidden="true"></div>

      {%- if section.settings.enable_filtering or section.settings.enable_sorting -%}
        <aside
          aria-labelledby="verticalTitle"
          class="facets-wrapper{% unless section.settings.enable_filtering %} facets-wrapper--no-filters{% endunless %}"
          id="main-collection-filters"
          data-id="{{ section.id }}"
        >
          {%- comment -%} MISC: mobile drawer header (hidden on desktop via CSS) {%- endcomment -%}
          <div class="sidebar__mobile-header">
            <span class="sidebar__mobile-title">Filters</span>
            <button type="button" class="sidebar__mobile-close" data-close-drawer aria-label="Close filters">
              {{- 'icon-close.svg' | inline_asset_content -}}
            </button>
          </div>

          {%- comment -%} MISC: render our custom sidebar instead of Trade's facets {%- endcomment -%}
          {% render 'misc-facets',
            results: collection,
            enable_filtering: section.settings.enable_filtering,
            enable_sorting: section.settings.enable_sorting,
            paginate: paginate
          %}

          {%- comment -%} MISC: mobile drawer footer (hidden on desktop via CSS) {%- endcomment -%}
          <div class="sidebar__mobile-footer">
            <button type="button" class="sidebar__mobile-apply" data-close-drawer>
              Show {{ collection.products_count }} products
            </button>
          </div>
        </aside>
      {%- endif -%}

      <div
        class="product-grid-container{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}"
        id="ProductGridContainer"
        data-active-layout="{{ active_view }}"
        {% if settings.animations_reveal_on_scroll %}data-cascade{% endif %}
      >
        {%- if collection.products.size == 0 -%}
          <div class="collection collection--empty" id="product-grid" data-id="{{ section.id }}">
            <div class="loading-overlay gradient"></div>
            <div class="title-wrapper center">
              <h2 class="title title--primary">
                {{ 'sections.collection_template.empty' | t -}}
                <br>
                {{
                  'sections.collection_template.use_fewer_filters_html'
                  | t: link: collection.url, class: 'underlined-link link'
                }}
              </h2>
            </div>
          </div>
        {%- else -%}
          <div class="collection">
            <div class="loading-overlay gradient"></div>

            {%- comment -%}
              MISC: grid view. id="product-grid" required by facets.js so it can
              read the section ID via dataset.id for the AJAX request.
            {%- endcomment -%}
            <ul
              id="product-grid"
              data-id="{{ section.id }}"
              class="product-grid{% if active_view == 'grid-5' %} is-cols-5{% endif %}"
              {% if active_view == 'list' %}hidden{% endif %}
            >
              {%- for product in collection.products -%}
                {%- assign lazy_load = false -%}
                {%- if forloop.index > 6 -%}
                  {%- assign lazy_load = true -%}
                {%- endif -%}
                <li>
                  {% render 'misc-card-product',
                    card_product: product,
                    lazy_load: lazy_load,
                    section_id: section.id
                  %}
                </li>
              {%- endfor -%}
            </ul>

            {%- comment -%} MISC: list view (table) — Phase 9 {%- endcomment -%}
            {%- if section.settings.enable_list_view -%}
              {% render 'misc-product-list',
                collection: collection,
                active_view: active_view
              %}
            {%- endif -%}

            {%- if paginate.pages > 1 -%}
              {% render 'pagination', paginate: paginate, anchor: '' %}
            {%- endif -%}
          </div>
        {%- endif -%}
      </div>
    </div>
  {%- endpaginate -%}
</div>

<script src="{{ 'misc-view-toggle.js' | asset_url }}" defer="defer"></script>

{% schema %}
{
  "name": "MISC catalog grid",
  "class": "section",
  "settings": [
    {
      "type": "header",
      "content": "Display"
    },
    {
      "type": "select",
      "id": "products_per_page",
      "default": "48",
      "label": "Products per page (default)",
      "info": "Shopify defaults. Buyer can change this per session via the Per page dropdown.",
      "options": [
        { "value": "24", "label": "24" },
        { "value": "48", "label": "48" },
        { "value": "72", "label": "72" },
        { "value": "96", "label": "96" }
      ]
    },
    {
      "type": "select",
      "id": "default_view",
      "default": "grid-3",
      "label": "Default view",
      "info": "Buyer can switch via the Grid 3 / Grid 5 / List toggle above the grid.",
      "options": [
        { "value": "grid-3", "label": "Grid (3 columns)" },
        { "value": "grid-5", "label": "Grid (5 columns)" },
        { "value": "list",   "label": "List (table)" }
      ]
    },
    {
      "type": "checkbox",
      "id": "enable_list_view",
      "default": true,
      "label": "Allow List view",
      "info": "Hide the List button in the view toggle if your catalog doesn't suit a table layout."
    },
    {
      "type": "checkbox",
      "id": "enable_search",
      "default": true,
      "label": "Show catalog search bar in the hero"
    },
    {
      "type": "header",
      "content": "Filters and sorting"
    },
    {
      "type": "checkbox",
      "id": "enable_filtering",
      "default": true,
      "label": "Enable filters"
    },
    {
      "type": "checkbox",
      "id": "enable_sorting",
      "default": true,
      "label": "Enable sort"
    },
    {
      "type": "header",
      "content": "Section padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Top padding",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Bottom padding",
      "default": 0
    }
  ]
}
{% endschema %}
