{%- comment -%}
  MISC header — fork of Trade's sections/header.liquid
  Forked: 2026-05-30
  Replaces Trade's header entirely for the MISC theme. Renders:
    1. Utility bar  (email, phone, instagram)
    2. Main header  (logo · search · account state · cart)
    3. Primary nav  (from linklists[section.settings.menu], fallback to hardcoded)

  Why a fork (not an edit): Trade's header.liquid is 600+ lines of
  drawer/mega-menu/predictive-search machinery and visual chrome
  we're replacing wholesale. Forking keeps Trade's core untouched.

  Editability: every visible string is a section setting.
  Auth state: rendered server-side from `customer != blank`, no JS.
{%- endcomment -%}

{%- comment -%} CSS loaded once globally from layout/theme.liquid {%- endcomment -%}

{%- liquid
  assign nav_menu = linklists[section.settings.menu]
  assign has_menu_items = false
  if nav_menu.links.size > 0
    assign has_menu_items = true
  endif
-%}

{%- if section.settings.show_utility_bar -%}
  <div class="misc-utility-bar">
    <div class="misc-utility-bar__left">
      {%- if section.settings.utility_email != blank -%}
        <a href="mailto:{{ section.settings.utility_email }}">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><path d="M3 7l9 6 9-6M3 7v10a1 1 0 001 1h16a1 1 0 001-1V7M3 7l9-4 9 4"/></svg>
          <span>{{ section.settings.utility_email }}</span>
        </a>
      {%- endif -%}
      {%- if section.settings.utility_phone != blank -%}
        <a href="tel:{{ section.settings.utility_phone | replace: ' ', '' }}">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6 19.79 19.79 0 01-3.07-8.67A2 2 0 014.11 2h3a2 2 0 012 1.72c.13.96.37 1.9.72 2.81a2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.91.35 1.85.59 2.81.72A2 2 0 0122 16.92z"/></svg>
          <span>{{ section.settings.utility_phone }}</span>
        </a>
      {%- endif -%}
    </div>
    <div class="misc-utility-bar__right">
      {%- if section.settings.utility_instagram != blank -%}
        <a href="{{ section.settings.utility_instagram }}" target="_blank" rel="noopener" aria-label="Instagram">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><rect x="2" y="2" width="20" height="20" rx="5"/><circle cx="12" cy="12" r="4"/><circle cx="17.5" cy="6.5" r="1" fill="currentColor"/></svg>
        </a>
      {%- endif -%}
    </div>
  </div>
{%- endif -%}

<header class="misc-site-header">
  <div class="misc-site-header__main">
    <a href="{{ routes.root_url }}" class="misc-site-header__logo">
      {%- if section.settings.logo != blank -%}
        {{ section.settings.logo | image_url: width: 700 | image_tag: loading: 'eager', class: 'misc-site-header__logo-img', alt: shop.name }}
      {%- else -%}
        {{ section.settings.logo_text | default: shop.name }}
      {%- endif -%}
    </a>

    <form action="{{ routes.search_url }}" method="get" role="search" class="misc-site-header__search">
      <svg viewBox="0 0 18 18" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
        <circle cx="8" cy="8" r="6"/><path d="M16 16l-3.5-3.5"/>
      </svg>
      <input type="search" name="q" placeholder="{{ section.settings.search_placeholder | default: 'Search products, SKUs, brands' }}" aria-label="Search">
    </form>

    <div class="misc-site-header__right">
      <div class="misc-site-header__account">
        {%- if customer != blank -%}
          {%- assign first_initial = customer.first_name | slice: 0, 1 | upcase -%}
          {%- if first_initial == blank -%}{%- assign first_initial = customer.email | slice: 0, 1 | upcase -%}{%- endif -%}
          <a href="{{ routes.account_url }}" class="misc-site-header__account-mine">
            <span class="misc-avatar">{{ first_initial }}</span>
            My Account
          </a>
        {%- else -%}
          <a href="{{ routes.account_register_url }}" class="misc-site-header__account-link">Register Account</a>
          <span class="misc-site-header__account-divider"></span>
          <a href="{{ routes.account_login_url }}" class="misc-site-header__account-link misc-site-header__account-link--primary">Sign In</a>
        {%- endif -%}
      </div>

      <a href="{{ routes.cart_url }}" class="misc-site-header__cart" aria-label="Cart">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><path d="M3 3h2l2.4 12.5a2 2 0 002 1.5h9.2a2 2 0 002-1.5L22 6H6"/><circle cx="9" cy="20" r="1.5"/><circle cx="18" cy="20" r="1.5"/></svg>
        <span class="misc-site-header__cart-count{% if cart.item_count == 0 %} is-empty{% endif %}">{{ cart.item_count }}</span>
      </a>
    </div>
  </div>
</header>

<nav class="misc-site-nav" aria-label="Primary">
  <ul class="misc-site-nav__inner">
    {%- if has_menu_items -%}
      {%- for link in nav_menu.links -%}
        <li>
          <a href="{{ link.url }}" class="misc-site-nav__item{% if link.active %} is-active{% endif %}">{{ link.title }}</a>
        </li>
      {%- endfor -%}
    {%- else -%}
      {%- comment -%} Fallback if the menu isn't set up yet {%- endcomment -%}
      <li><a href="{{ routes.root_url }}" class="misc-site-nav__item{% if template == 'index' %} is-active{% endif %}">Home</a></li>
      <li><a href="{{ routes.collections_url }}" class="misc-site-nav__item">Catalogue</a></li>
      <li><a href="{{ routes.collections_url }}" class="misc-site-nav__item">Curated Collections</a></li>
    {%- endif -%}
  </ul>
</nav>

{% schema %}
{
  "name": "MISC Header",
  "settings": [
    {
      "type": "header",
      "content": "Logo"
    },
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Logo image"
    },
    {
      "type": "text",
      "id": "logo_text",
      "label": "Logo text (wordmark)",
      "default": "Misc.Distribution"
    },
    {
      "type": "header",
      "content": "Search"
    },
    {
      "type": "text",
      "id": "search_placeholder",
      "label": "Search placeholder",
      "default": "Search products, SKUs, brands"
    },
    {
      "type": "header",
      "content": "Primary navigation"
    },
    {
      "type": "link_list",
      "id": "menu",
      "label": "Menu",
      "default": "main-menu"
    },
    {
      "type": "header",
      "content": "Utility bar"
    },
    {
      "type": "checkbox",
      "id": "show_utility_bar",
      "label": "Show utility bar above header",
      "default": true
    },
    {
      "type": "text",
      "id": "utility_email",
      "label": "Email",
      "default": "hello@misc-distribution.com"
    },
    {
      "type": "text",
      "id": "utility_phone",
      "label": "Phone",
      "default": "+31 20 261 38 66"
    },
    {
      "type": "text",
      "id": "utility_instagram",
      "label": "Instagram URL",
      "default": "http://instagram.com/misc.distribution"
    }
  ]
}
{% endschema %}
