{%- comment -%}
  ============================================================
  MISC Curated Collection — one reusable section per collection
  ------------------------------------------------------------
  Each curated collection is a Page with its own template that
  references this section (same pattern as the brand pages).

  Curation is done entirely from the Theme Editor. Each product
  is a "product" block whose settings answer the two questions:
    - Display size  -> how the product is shown (full / two / three per row)
    - Add-all qty   -> the quantity used by "Add collection to cart"
    - Description    -> optional per-collection override of the copy
    - Product        -> the product (its first available variant is used)

  "Add collection to cart" reads every block's variant + add-all
  quantity and posts them to the cart in one request (see
  assets/misc-curated-collection.js). Individual steppers set
  that product's quantity in the cart directly (catalogue logic,
  plus/minus only, no add button).

  CSS: assets/misc-curated-collection.css
  JS:  assets/misc-curated-collection.js
  Used by: templates/page.misc-curated-*.json
  ============================================================
{%- endcomment -%}

{{ 'misc-curated-collection.css' | asset_url | stylesheet_tag }}
<script src="{{ 'misc-curated-collection.js' | asset_url }}" defer="defer"></script>

{%- liquid
  assign rule = section.settings.rule_weight | default: 3
  assign product_blocks = section.blocks

  assign total_cents = 0
  assign total_units = 0
  assign items_json = ''
  for block in product_blocks
    assign v = block.settings.product.selected_or_first_available_variant
    if v
      assign q = block.settings.add_qty | default: 1
      assign line = v.price | times: q
      assign total_cents = total_cents | plus: line
      assign total_units = total_units | plus: q
      assign items_json = items_json | append: ',{"id":' | append: v.id | append: ',"quantity":' | append: q | append: '}'
    endif
  endfor
  assign items_json = items_json | remove_first: ','
-%}

<section
  class="misc-curated"
  style="--misc-cc-rule: {{ rule }}px; padding-top: {{ section.settings.padding_top }}px; padding-bottom: {{ section.settings.padding_bottom }}px;"
  aria-label="{{ section.settings.title | default: 'Curated collection' | escape }}"
>
  <div class="misc-curated__head">
    <div class="misc-curated__intro">
      {%- if section.settings.eyebrow != blank or section.settings.brand != blank -%}
        <p class="misc-curated__eyebrow">
          {{- section.settings.eyebrow -}}
          {%- if section.settings.eyebrow != blank and section.settings.brand != blank %} &middot; {% endif -%}
          {{- section.settings.brand -}}
        </p>
      {%- endif -%}
      <h1 class="misc-curated__title">{{ section.settings.title | default: 'Curated collection' }}</h1>
      {%- if section.settings.description != blank -%}
        <p class="misc-curated__desc">{{ section.settings.description }}</p>
      {%- endif -%}
    </div>

    {%- if items_json != blank -%}
      <div class="misc-curated__addwrap">
        <button type="button" class="misc-curated__addall" id="MiscCuratedAddAll" data-items='[{{ items_json }}]'>
          <span class="misc-curated__addall-label">{{ section.settings.add_all_label | default: 'Add collection to cart' }}</span>
          <span class="misc-curated__addall-total">{{ total_cents | money }}</span>
        </button>
        <p class="misc-curated__addnote">{{ total_units }} units &middot; you can always adjust quantities in the cart</p>
      </div>
    {%- endif -%}
  </div>

  <div class="misc-curated__grid">
    {%- for block in product_blocks -%}
      {%- assign product = block.settings.product -%}
      {%- assign v = product.selected_or_first_available_variant -%}
      {%- assign size = block.settings.size | default: 'half' -%}
      <article class="misc-curated__product misc-curated__product--{{ size }}" {{ block.shopify_attributes }}>
        <figure class="misc-curated__media">
          {%- if product.featured_image -%}
            {{ product.featured_image | image_url: width: 1000 | image_tag:
                loading: 'lazy',
                widths: '320, 480, 720, 1000',
                sizes: '(max-width: 1000px) 100vw, 33vw',
                alt: product.title }}
          {%- endif -%}
        </figure>
        <div class="misc-curated__body">
          <p class="misc-curated__eyebrow">{{ section.settings.brand | default: product.vendor }}</p>
          <h3 class="misc-curated__name">{{ product.title }}</h3>
          <div class="misc-curated__prose">
            {%- if block.settings.description != blank -%}
              {{ block.settings.description }}
            {%- else -%}
              <p>{{ product.description | strip_html | truncatewords: 28 }}</p>
            {%- endif -%}
          </div>
          {%- if v.sku != blank -%}<p class="misc-curated__sku">{{ v.sku }}</p>{%- endif -%}
          {%- if v.available -%}
            <span class="misc-curated__state misc-curated__state--instock">In stock</span>
          {%- else -%}
            <span class="misc-curated__state misc-curated__state--backorder">Backorder</span>
          {%- endif -%}
          <div class="misc-curated__price">{{ v.price | money }}</div>
          <div class="misc-curated__actions">
            <span class="misc-curated__qtylabel">Qty</span>
            <div class="misc-curated__stepper" data-variant-id="{{ v.id }}">
              <button type="button" data-step="-1" aria-label="Decrease quantity">&minus;</button>
              <input type="number" class="misc-curated__qty" value="0" min="0" inputmode="numeric" aria-label="Quantity for {{ product.title | escape }}">
              <button type="button" data-step="1" aria-label="Increase quantity">+</button>
            </div>
          </div>
        </div>
      </article>
    {%- endfor -%}
  </div>
</section>

{% schema %}
{
  "name": "MISC Curated Collection",
  "tag": "section",
  "class": "misc-curated-section",
  "max_blocks": 50,
  "settings": [
    { "type": "header", "content": "Header" },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Curated" },
    { "type": "text", "id": "brand", "label": "Brand", "default": "Penco" },
    { "type": "text", "id": "title", "label": "Collection name (h1)", "default": "Analog Americana" },
    { "type": "textarea", "id": "description", "label": "Intro description" },
    { "type": "text", "id": "add_all_label", "label": "Add-all button label", "default": "Add collection to cart" },
    { "type": "header", "content": "Layout" },
    { "type": "range", "id": "rule_weight", "label": "Divider thickness", "min": 1, "max": 6, "step": 1, "unit": "px", "default": 3 },
    { "type": "range", "id": "padding_top", "label": "Padding top", "min": 0, "max": 120, "step": 4, "unit": "px", "default": 48 },
    { "type": "range", "id": "padding_bottom", "label": "Padding bottom", "min": 0, "max": 120, "step": 4, "unit": "px", "default": 64 }
  ],
  "blocks": [
    {
      "type": "product",
      "name": "Product",
      "settings": [
        { "type": "product", "id": "product", "label": "Product" },
        {
          "type": "select",
          "id": "size",
          "label": "Display size",
          "options": [
            { "value": "full", "label": "Full row (1 per row)" },
            { "value": "half", "label": "Two per row" },
            { "value": "third", "label": "Three per row" }
          ],
          "default": "half"
        },
        { "type": "number", "id": "add_qty", "label": "Add-all quantity", "default": 6 },
        { "type": "richtext", "id": "description", "label": "Description override (optional)" }
      ]
    }
  ],
  "presets": [
    {
      "name": "MISC Curated Collection",
      "blocks": [
        { "type": "product" },
        { "type": "product" },
        { "type": "product" }
      ]
    }
  ]
}
{% endschema %}
